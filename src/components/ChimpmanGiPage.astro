---
import LeadForm from "./LeadForm.astro";
import type { ProgramPage } from "../data/site";

type Props = {
  program: ProgramPage;
};

const { program } = Astro.props;
---

<section class="chimpangi-poster">
  <div class="shell chimpangi-shell">
    <aside class="chimpangi-sidebar">
      <div class="chimpangi-logo-card">
        <div class="chimpangi-logo-wrap">
          <img
            src="/images/chimpangi-logo.jpg"
            alt="ChimpmanGi logo"
            width="1284"
            height="1828"
            loading="eager"
            decoding="async" />
        </div>
      </div>
      <LeadForm
        config={{
          title: "Join the ChimpmanGi Troop",
          intro:
            "Be first in line for early access, limited releases, and the next drop announcement.",
          submitLabel: "Notify Me",
          hideProgramSelect: true,
          defaultProgram: "ChimpmanGi",
          fields: "emailOnly"
        }}
      />
    </aside>

    <div class="chimpangi-copy">
      <p class="chimpangi-tag">Burning Tree Exclusive</p>
      <h1>{program.hero.title}</h1>
      <p class="chimpangi-lead">
        One roll and you will know it is different. ChimpmanGi is built for practitioners who care
        about performance, comfort, and a cleaner way to train.
      </p>

      <div class="chimpangi-actions">
        <a class="button" href="#lead-form">Join the ChimpmanGi Troop</a>
      </div>

      <div class="chimpangi-points">
        <article>
          <h2>Unmatched Durability</h2>
          <p>Built to keep its shape and feel through hard rounds, repeated washes, and daily training.</p>
        </article>
        <article>
          <h2>Natural Breathability</h2>
          <p>Designed to stay light, move cleanly, and feel comfortable during long sessions on the mat.</p>
        </article>
        <article>
          <h2>Sustainable Impact</h2>
          <p>A gear story rooted in conscious materials and a product identity that stands apart from standard cotton gis.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<section class="shell section-divider">
  <div class="gallery-grid" data-gallery-grid>
    {program.galleryImages.map((image, i) => (
      <figure class="gallery-card" data-gallery-index={i} role="button" tabindex="0" aria-label={`View ${image.alt}`}>
        <img
          src={image.src}
          alt={image.alt}
          loading="lazy"
          decoding="async"
          width="1600"
          height="1100" />
      </figure>
    ))}
  </div>
</section>

<div class="gallery-lightbox" data-gallery-lightbox aria-hidden="true" aria-modal="true" role="dialog">
  <button class="gallery-lightbox-close" data-gallery-close aria-label="Close">&#10005;</button>
  <button class="gallery-btn gallery-btn-prev" data-gallery-prev aria-label="Previous image">&#8592;</button>
  <figure class="gallery-lightbox-figure">
    <img src="" alt="" class="gallery-lightbox-img" data-gallery-img loading="lazy" decoding="async" />
  </figure>
  <button class="gallery-btn gallery-btn-next" data-gallery-next aria-label="Next image">&#8594;</button>
  <div class="gallery-dots" aria-hidden="true">
    {program.galleryImages.map(() => (
      <span class="gallery-dot"></span>
    ))}
  </div>
</div>

<script is:inline>
  (function () {
    var grid = document.querySelector("[data-gallery-grid]");
    var lightbox = document.querySelector("[data-gallery-lightbox]");
    if (!grid || !lightbox || lightbox.dataset.bound === "true") return;
    lightbox.dataset.bound = "true";

    var thumbs = Array.prototype.slice.call(grid.querySelectorAll("[data-gallery-index]"));
    var lbImg = lightbox.querySelector("[data-gallery-img]");
    var dots = Array.prototype.slice.call(lightbox.querySelectorAll(".gallery-dot"));
    var current = 0;

    var images = thumbs.map(function (thumb) {
      var img = thumb.querySelector("img");
      return { src: img.getAttribute("src"), alt: img.getAttribute("alt") };
    });

    function show(n) {
      current = ((n % images.length) + images.length) % images.length;
      lbImg.setAttribute("src", images[current].src);
      lbImg.setAttribute("alt", images[current].alt);
      dots.forEach(function (d, i) { d.classList.toggle("is-active", i === current); });
    }

    function open(n) {
      show(n);
      lightbox.removeAttribute("aria-hidden");
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";
    }

    function close() {
      lightbox.setAttribute("aria-hidden", "true");
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
    }

    thumbs.forEach(function (thumb) {
      thumb.addEventListener("click", function () {
        open(parseInt(thumb.dataset.galleryIndex, 10));
      });
      thumb.addEventListener("keydown", function (e) {
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); open(parseInt(thumb.dataset.galleryIndex, 10)); }
      });
    });

    lightbox.querySelector("[data-gallery-prev]").addEventListener("click", function () { show(current - 1); });
    lightbox.querySelector("[data-gallery-next]").addEventListener("click", function () { show(current + 1); });
    lightbox.querySelector("[data-gallery-close]").addEventListener("click", close);
    lightbox.addEventListener("click", function (e) { if (e.target === lightbox) close(); });
    document.addEventListener("keydown", function (e) {
      if (!lightbox.classList.contains("is-open")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") show(current - 1);
      if (e.key === "ArrowRight") show(current + 1);
    });
  })();
</script>

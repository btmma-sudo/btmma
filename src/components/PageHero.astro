---
import type { HeroContent, LeadFormConfig } from "../data/site";
import LeadForm from "./LeadForm.astro";

type Props = {
  hero: HeroContent;
  large?: boolean;
  leadForm?: LeadFormConfig;
};

const { hero, large = false, leadForm } = Astro.props;
const overlayClass = hero.overlay === "medium" ? "hero-overlay-medium" : "hero-overlay-strong";
---

<section
  class:list={[
    "hero-banner",
    "hero-left",
    overlayClass,
    large && "hero-large"
  ]}>
  <div class="hero-media" aria-hidden="true">
    <img
      class="hero-image"
      src={hero.image}
      alt=""
      decoding="async"
      fetchpriority={large ? "high" : "auto"} />
  </div>
  <div class="shell hero-shell hero-with-form">
    <div class="hero-content">
      <h1>{hero.title}</h1>
    </div>
    {leadForm && (
      <div class="hero-lead-form">
        <LeadForm config={leadForm} />
      </div>
    )}
  </div>
</section>

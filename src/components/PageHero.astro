---
import type { HeroContent, LeadFormConfig } from "../data/site";
import LeadForm from "./LeadForm.astro";

type Props = {
  hero: HeroContent;
  large?: boolean;
  leadForm?: LeadFormConfig;
};

const { hero, large = false, leadForm } = Astro.props;
const overlayClass = hero.overlay === "medium" ? "hero-overlay-medium" : "hero-overlay-strong";
---

<section
  class:list={[
    "hero-banner",
    "hero-left",
    overlayClass,
    large && "hero-large"
  ]}>
  <div class="hero-media">
    <img
      class="hero-image"
      src={hero.image}
      alt={hero.imageAlt ?? ""}
      width="1600"
      height="900"
      loading={large ? "eager" : undefined}
      decoding="async"
      fetchpriority={large ? "high" : "auto"} />
  </div>
  <div class:list={["shell", "hero-shell", leadForm && "hero-with-form"]}>
    <div class="hero-content">
      <h1>{hero.title}</h1>
      {!leadForm && (
        <a class="button hero-mobile-cta" href="#lead-form">Try a Free Class</a>
      )}
    </div>
    {leadForm && (
      <div class="hero-lead-form">
        <LeadForm config={leadForm} />
      </div>
    )}
  </div>
</section>

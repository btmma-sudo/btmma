---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ProgramDetail from "../components/ProgramDetail.astro";
import ChimpanGiPage from "../components/ChimpanGiPage.astro";
import { programPages } from "../data/site";

export function getStaticPaths() {
  return programPages.map((program) => ({
    params: { slug: program.slug },
    props: { program }
  }));
}

const { program } = Astro.props;
const isChimpanGi = program.slug === "chimpman-gi";
---

<BaseLayout
  title={program.seo.title}
  description={program.seo.description}
  path={`/${program.slug}`}
  keywords={program.seo.keywords}
  image={program.hero.image}
  theme={program.accentTheme ?? "flame"}>
  {isChimpanGi ? (
    <ChimpanGiPage program={program} />
  ) : (
    <>
      <PageHero hero={program.hero} leadForm={program.leadForm} />
      <ProgramDetail program={program} />
    </>
  )}
</BaseLayout>

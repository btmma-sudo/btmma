---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ProgramDetail from "../components/ProgramDetail.astro";
import ChimpmanGiPage from "../components/ChimpmanGiPage.astro";
import LeadForm from "../components/LeadForm.astro";
import WellnessBooking from "../components/WellnessBooking.astro";
import { programPages } from "../data/site";

export function getStaticPaths() {
  return programPages.map((program) => ({
    params: { slug: program.slug },
    props: { program }
  }));
}

const { program } = Astro.props;
const isChimpmanGi  = program.slug === "chimpman-gi";
const isWellness    = program.slug === "health-and-wellness";
const isBirthday    = program.slug === "birthday-parties";
const showLeadForm  = program.showLeadForm !== false;
const centerContent = !isWellness && !isBirthday;
---

<BaseLayout
  title={program.seo.title}
  description={program.seo.description}
  path={`/${program.slug}`}
  keywords={program.seo.keywords}
  image={program.hero.image}
  theme={program.accentTheme ?? "flame"}>
  {isChimpmanGi ? (
    <ChimpmanGiPage program={program} />
  ) : (
    <>
      <div class="hero-form-layout hero-form-layout--program">
        <PageHero hero={program.hero} showMobileCta={showLeadForm} ctaLabel={program.mobileCta} centerMobile={isWellness} centerContent={centerContent} />
        {showLeadForm && (
          <div class="hero-form-float hero-form-float--program">
            <LeadForm config={program.leadForm} />
          </div>
        )}
      </div>
      <ProgramDetail program={program} />
      {isWellness && <WellnessBooking />}
    </>
  )}
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ClassSchedule from "../components/ClassSchedule.astro";
import LeadForm from "../components/LeadForm.astro";
import GalleryCarousel from "../components/GalleryCarousel.astro";
import { homePage, homepagePrograms } from "../data/site";
---

<BaseLayout
  title={homePage.seo.title}
  description={homePage.seo.description}
  path="/"
  keywords={homePage.seo.keywords}
  image={homePage.hero.image}>
  <div class="hero-form-layout">
    <PageHero hero={homePage.hero} large centerContent />
    <GalleryCarousel />
    <div class="hero-form-float">
      <LeadForm config={homePage.leadForm} />
    </div>
  </div>

  <section class="shell section-divider">
    <div class="section-heading">
      <div>
        <h2>Our Programs</h2>
      </div>
    </div>

    <div class="card-grid program-grid">
      {homepagePrograms.map((program) => (
        <article class="program-card">
          {program.image && (
            <div class="program-card-image">
              <img src={program.image} alt={program.imageAlt ?? program.title} loading="lazy" decoding="async" width="600" height="400" />
            </div>
          )}
          <div class="program-card-body">
            <p class="eyebrow">{program.eyebrow}</p>
            <h3>{program.title}</h3>
            <p>{program.summary}</p>
            <a class="button" href={program.href}>View Program</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <ClassSchedule ctaHref="#lead-form" />

  <section class="shell section-divider">
    <article class="detail-card narrative-section">
      <h2>About Burning Tree MMA</h2>
      <p>
        At Burning Tree Mixed Martial Arts in Owings Mills, we combine tradition and
        modern training to help students of all ages grow stronger in mind, body, and
        spirit. Guided by respect, perseverance, and community, we aim to create a
        place where families and individuals can train seriously while feeling supported.
      </p>
      <p>
        Our mission is to help students build real confidence, strengthen both mind and
        body, and develop discipline through martial training that is practical,
        structured, and welcoming.
      </p>
    </article>
  </section>

  <section class="shell section-divider">
    <div class="section-heading">
      <div>
        <h2>Testimonials</h2>
      </div>
    </div>

    <div class="card-grid">
      <blockquote class="quote-card">
        <p>"Best place ever for mixed martial arts. My child is super happy there, come and try today!"</p>
        <footer>Shoshana S.</footer>
      </blockquote>
      <blockquote class="quote-card">
        <p>"Great place to be for the best experience in martial arts."</p>
        <footer>Zainab A.</footer>
      </blockquote>
      <blockquote class="quote-card">
        <p>"My grandson has learned discipline, confidence and martial arts techniques. I am so glad my husband made the decision to enroll him, it was the best choice."</p>
        <footer>Kelly W.</footer>
      </blockquote>
    </div>
  </section>
</BaseLayout>
